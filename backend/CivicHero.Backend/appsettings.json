{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=CivicHeroDb;User=root;Password=cdac;TreatTinyAsBoolean=true;"
  },

  "Database": {
    "CommandTimeout": 30,
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false
  },

  "Jwt": {
    "Issuer": "CivicHero",
    "Audience": "CivicHeroClient",
    "SecretKey": "ReplaceThisWithAVeryLongSecretKeyAtLeast32CharactersLong123!",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },

  "AI": {
    "ModelPath": "Models/llama.gguf",
    "EnableLocalModel": true,
    "Temperature": 0.7,
    "MaxTokens": 2048
  },

  "Mapbox": {
    "AccessToken": "",
    "BaseUrl": "https://api.mapbox.com"
  },

  "Redis": {
    "ConnectionString": "localhost:6379"
  },

  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest"
  },

  "AllowedHosts": "*",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  }

}
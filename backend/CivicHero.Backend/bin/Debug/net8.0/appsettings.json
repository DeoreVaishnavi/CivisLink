{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=CivicHeroDb;User=root;Password=cdac;TreatTinyAsBoolean=true;"
  },

  "Database": {
    "CommandTimeout": 30,
    "EnableSensitiveDataLogging": false,
    "EnableDetailedErrors": false
  },

  "Jwt": {
    "Issuer": "",
    "Audience": "",
    "SecretKey": "",
    "ExpirationMinutes": 60
  },

  "Ai": {
    "ModelPath": ""
  },

  "Mapbox": {
    "AccessToken": ""
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "shared": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },

  "AllowedHosts": "*"
}